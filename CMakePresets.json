{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_COM_ETH": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_COM_FBDK": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_COM_LOCAL": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_MODULE_CONVERT": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_MODULE_IEC61131": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_MODULE_UTILS": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "base-tests",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "FORTE_COM_HTTP": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_COM_RAW": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_COM_SER": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_COM_STRUCT_MEMBER": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_IO": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_MODULE_RECONFIGURATION": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_MODULE_RT_Events": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_MODULE_SIGNALPROCESSING": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_TESTS": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_TEST_SANITIZE": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "tests",
      "hidden": true,
      "inherits": "base-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        },
        "FORTE_BUILD_STATIC_LIBRARY": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_BUILD_SHARED_LIBRARY": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_C_INTERFACE": {
          "type": "BOOL",
          "value": "ON"
        },
        "FORTE_TRACE_CTF": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "systemtests",
      "hidden": true,
      "inherits": "base-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        },
        "FORTE_SYSTEM_TESTS": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "shared",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "posix",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_INSTALL_RPATH": {
          "type": "STRING",
          "value": "$ORIGIN/../lib"
        },
        "CMAKE_INSTALL_RPATH_USE_LINK_PATH": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "posix-debug",
      "displayName": "Debug (Posix)",
      "inherits": "posix",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        }
      }
    },
    {
      "name": "posix-release",
      "displayName": "Release (Posix)",
      "inherits": "posix",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Release"
        }
      }
    },
    {
      "name": "posix-shared",
      "hidden": true,
      "inherits": [
        "posix",
        "shared"
      ]
    },
    {
      "name": "posix-shared-debug",
      "displayName": "Debug (Posix, Shared Libraries)",
      "inherits": "posix-shared",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        }
      }
    },
    {
      "name": "posix-shared-release",
      "displayName": "Release (Posix, Shared Libraries)",
      "inherits": "posix-shared",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Release"
        }
      }
    },
    {
      "name": "posix-tests",
      "displayName": "Tests (Posix)",
      "inherits": [
        "tests",
        "posix"
      ]
    },
    {
      "name": "posix-systemtests",
      "displayName": "System Tests (Posix)",
      "inherits": [
        "systemtests",
        "posix"
      ]
    },
    {
      "name": "windows",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Debug (Windows)",
      "inherits": "windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        }
      }
    },
    {
      "name": "windows-release",
      "displayName": "Release (Windows)",
      "inherits": "windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Release"
        }
      }
    },
    {
      "name": "windows-shared",
      "hidden": true,
      "inherits": [
        "windows",
        "shared"
      ],
      "cacheVariables": {
        "WINDOWS_EXPORT_ALL_SYMBOLS": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "windows-shared-debug",
      "displayName": "Debug (Windows, Shared Libraries)",
      "inherits": "windows-shared",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        }
      }
    },
    {
      "name": "windows-shared-release",
      "displayName": "Release (Windows, Shared Libraries)",
      "inherits": "windows-shared",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Release"
        }
      }
    },
    {
      "name": "windows-tests",
      "displayName": "Tests (Windows)",
      "inherits": [
        "tests",
        "windows"
      ]
    },
    {
      "name": "windows-systemtests",
      "displayName": "System Tests (Windows)",
      "inherits": [
        "systemtests",
        "windows"
      ]
    }
  ]
}
