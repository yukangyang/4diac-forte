#include "arch/timerha.h"
#include "core/devexec.h"
#include "core/timerhandlerfactory.h"

${includes}

enum class classindex {
  CTimerHandler,
#define ENTRY(name) \
  name,
  ${entries}
#undef ENTRY
  len
};

const size_t CTimerHandler::mHandlerIdentifier = size_t(classindex::CTimerHandler);
#define ENTRY(name) \
const size_t name::mHandlerIdentifier = size_t(classindex::name);
${entries}
#undef ENTRY

CDeviceExecution::CDeviceExecution(CDevice& paDevice) :
  mDevice(paDevice), mRegisteredEventHandlers(size_t(classindex::len)) {
  mRegisteredEventHandlers[0].mHandler = forte::core::TimerHandlerFactory::create(*this);
#define ENTRY(name) \
  mRegisteredEventHandlers[size_t(classindex::name)].mHandler = std::make_unique<name>(*this);
  ${entries}
#undef ENTRY
  getTimer().enableHandler();
}
